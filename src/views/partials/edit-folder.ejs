<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Edit Folder</h1>
    <form action="/edit-folder" method="POST">
        <input type="hidden" name="folderId" value="<%= folder.id %>">
        <label for="newName">New Folder Name:</label>
        <input type="text" id="newName" name="newName" value="<%= folder.name %>" required>
        <button type="submit">Update Folder</button>
    </form>

</body>
</html>