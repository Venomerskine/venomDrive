<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Welcome, <%= user.email %>!</h1>
    <h2>Your Files:</h2>
    <ul>
        <% user.files.forEach(file => { %>
            <li><%= file.name %></li>
        <% }); %>
    </ul>
</body>
</html>